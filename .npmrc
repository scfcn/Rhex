# ===== pnpm config for bbs/site =====
# 采用 hoisted 扁平 node_modules，最接近 npm 行为，避免 Next.js / Prisma / turbopack
# 在严格符号链接布局下某些边缘 bug；同时仍然享受 pnpm 的正确 libc/arch 筛选。
node-linker=hoisted

# 自动安装 peerDependencies（React 19 / Next 16 生态频繁需要）
auto-install-peers=true

# 不强制 peer 严格检查，避免大量 warn 阻塞
strict-peer-dependencies=false

# 只下载当前平台需要的原生 optional deps（彻底杜绝 linux-x64-gnu 与 musl 并存问题）
# 这是默认值，显式写一次以防未来 pnpm 改默认。
supported-architectures.os=current
supported-architectures.cpu=current
supported-architectures.libc=current
