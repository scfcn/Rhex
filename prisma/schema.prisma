model PostTip {
  id         String   @id @default(cuid())
  postId      String
  senderId    Int
  receiverId  Int
  amount      Int
  createdAt   DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  sender      User     @relation("PostTipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("PostTipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([postId, senderId, createdAt])
}

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  createdById Int?
  usedById    Int?
  usedAt      DateTime?
  expiresAt   DateTime?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("InviteCodeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  usedBy      User?    @relation("InviteCodeConsumer", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([usedById])
  @@index([createdAt])
}

model RedeemCode {
  id           String   @id @default(cuid())
  code         String   @unique
  points       Int
  createdById  Int?
  redeemedById Int?
  redeemedAt   DateTime?
  expiresAt    DateTime?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User?    @relation("RedeemCodeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  redeemedBy   User?    @relation("RedeemCodeConsumer", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([redeemedById])
  @@index([createdAt])
}

model VerificationCode {
  id          String              @id @default(cuid())
  channel     VerificationChannel
  target      String
  codeHash    String
  purpose     String
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(5)
  expiresAt   DateTime
  consumedAt  DateTime?
  sentByIp    String?
  userAgent   String?
  userId      Int?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([channel, target, purpose])
  @@index([expiresAt])
  @@index([userId])
}

model UserCheckInLog {
  id          String   @id @default(cuid())
  userId      Int
  reward      Int
  checkedInOn String
  isMakeUp    Boolean  @default(false)
  makeUpCost  Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkedInOn])
  @@index([userId])
  @@index([checkedInOn])
}

model UserLoginLog {
  id        String   @id @default(cuid())
  userId    Int
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
