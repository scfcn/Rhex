  siteName                      String
  siteSlogan                    String
  siteDescription               String
  siteLogoText                  String
  siteLogoPath                  String?
  siteSeoKeywords               String?  @default("")
  pointName                     String   @default("积分")
  analyticsCode                 String?
  friendLinksEnabled            Boolean  @default(true)
  friendLinkApplicationEnabled  Boolean  @default(true)
