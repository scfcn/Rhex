  postOfflineVip1Price          Int      @default(0)
  postOfflineVip2Price          Int      @default(0)
  postOfflineVip3Price          Int      @default(0)
  inviteRewardInviter           Int      @default(0)
  inviteRewardInvitee           Int      @default(0)
  registrationEnabled           Boolean  @default(true)
  registrationRequireInviteCode Boolean  @default(false)
  registerInviteCodeEnabled     Boolean  @default(true)
  inviteCodePurchaseEnabled     Boolean  @default(false)
  inviteCodePrice               Int      @default(0)
  registerCaptchaMode           String   @default("OFF")
  loginCaptchaMode              String   @default("OFF")
  turnstileSiteKey              String?
  nicknameChangePointCost       Int      @default(0)
  tippingEnabled                Boolean  @default(false)
  tippingDailyLimit             Int      @default(3)
  tippingPerPostLimit           Int      @default(1)
  tippingAmounts                String   @default("10,30,50,100")
  heatViewWeight                Int      @default(1)
  heatCommentWeight             Int      @default(8)
  heatLikeWeight                Int      @default(6)
  heatTipCountWeight            Int      @default(10)
  heatTipPointsWeight           Int      @default(1)
  heatStageThresholds           String   @default("0,80,180,320,520,780,1100,1500,2000")
  heatStageColors               String   @default("#4A4A4A,#808080,#9B8F7F,#B87333,#C4A777,#E8C547,#FFA500,#D96C3B,#C41E3A")
  registerEmailEnabled          Boolean  @default(false)
  registerEmailRequired         Boolean  @default(false)
  registerEmailVerification     Boolean  @default(false)
  registerPhoneEnabled          Boolean  @default(false)
  registerPhoneRequired         Boolean  @default(false)
  registerPhoneVerification     Boolean  @default(false)
  registerNicknameEnabled       Boolean  @default(true)
  registerNicknameRequired      Boolean  @default(false)
  registerGenderEnabled         Boolean  @default(false)
  registerGenderRequired        Boolean  @default(false)
  registerInviterEnabled        Boolean  @default(true)
  smtpEnabled                   Boolean  @default(false)
  smtpHost                      String?
  smtpPort                      Int?
  smtpUser                      String?
  smtpPass                      String?
  smtpFrom                      String?
  smtpSecure                    Boolean  @default(false)
  vipMonthlyPrice               Int      @default(30)
  vipQuarterlyPrice             Int      @default(88)
  vipYearlyPrice                Int      @default(288)
  uploadProvider                String   @default("local")
  uploadLocalPath               String   @default("uploads")
  uploadBaseUrl                 String?
  uploadOssBucket               String?
  uploadOssRegion               String?
  uploadOssEndpoint             String?
  uploadRequireLogin            Boolean  @default(true)
  uploadAllowedImageTypes       String   @default("jpg,jpeg,png,gif,webp")
  uploadMaxFileSizeMb           Int      @default(5)
  uploadAvatarMaxFileSizeMb     Int      @default(2)
  appStateJson               String?  @default("{}")
  footerLinksJson               String?  @default("[{\"label\":\"关于\",\"href\":\"/about\"},{\"label\":\"小黑屋\",\"href\":\"/prison\"},{\"label\":\"帮助文档\",\"href\":\"/help\"},{\"label\":\"FAQ\",\"href\":\"/faq\"},{\"label\":\"协议\",\"href\":\"/terms\"}]")
  createdAt                     DateTime @default(now())
