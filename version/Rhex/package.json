{
  "name": "site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "npm run build && npm run start",
    "setup": "tsx scripts/setup.ts",
    "setup:dev": "cross-env SETUP_MODE=development tsx scripts/setup.ts",
    "setup:prod": "cross-env SETUP_MODE=production tsx scripts/setup.ts",
    "setup:start": "npm run setup:dev && npm run dev",
    "setup:start:prod": "npm run setup:prod && npm run start:prod",
    "lint": "eslint . --ext .ts,.tsx",
    "plugins:generate": "tsx scripts/generate-plugin-bundles.ts",
    "version:sync": "tsx scripts/copy-release-to-version.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run setup:dev",
    "db:setup:prod": "npm run setup:prod"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "bcryptjs": "^3.0.3",
    "bignumber.js": "^10.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.40",
    "lucide-react": "^0.469.0",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.13.0",
    "next": "14.2.30",
    "nodemailer": "^6.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.30",
    "postcss": "8.5.0",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
