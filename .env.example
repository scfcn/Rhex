# =============================
# 必填：数据库与session密钥
# =============================
DATABASE_URL="postgresql://postgres:password@localhost:5432/bbs?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret"
CAPTCHA_SECRET_KEY="replace-with-a-long-random-secret"
REDIS_URL="redis://127.0.0.1:6379"
REDIS_KEY_PREFIX="rhex"
# 生产环境默认建议单独跑 `npm run worker`，Web/API 不再自动消费后台任务。
# 如需保留旧行为，可显式设为 "hybrid"；
BACKGROUND_JOB_WEB_RUNTIME="worker-only"
BACKGROUND_JOB_CONCURRENCY="11"
BACKGROUND_JOB_MAX_ATTEMPTS="3"
BACKGROUND_JOB_RETRY_BASE_MS="5000"
BACKGROUND_JOB_RETRY_MAX_MS="300000"

# =============================
# 可选：初始化管理员账号
# 仅首次执行 `npm run db:setup` / `npm run prisma:seed` 时使用
# =============================
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe_123456"
SEED_ADMIN_EMAIL="admin@rhex.im"
SEED_ADMIN_NICKNAME="秦始皇"
