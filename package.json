    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "8.5.0",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
