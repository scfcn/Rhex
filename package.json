{
  "name": "site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "npm run build && npm run start",
    "setup": "tsx scripts/setup.ts",
    "setup:dev": "cross-env SETUP_MODE=development tsx scripts/setup.ts",
    "setup:prod": "cross-env SETUP_MODE=production tsx scripts/setup.ts",
    "setup:start": "npm run setup:dev && npm run dev",
    "setup:start:prod": "npm run setup:prod && npm run start:prod",
    "lint": "eslint .",
    "version:sync": "tsx scripts/copy-release-to-version.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run setup:dev",
    "db:setup:prod": "npm run setup:prod"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-select": "^2.2.6",
